{
  "files.associations": {
    "renovate.json": "jsonc",
    ".envrc.project": "dotenv",
    ".envrc": "dotenv"
  },

  "explorer.fileNesting.patterns": {
    ".envrc.project": ".envrc",
    "flake.nix": "flake.lock,treefmt.toml",
    "README.md": "*.md,LICENSE"
  },

  "json.schemaDownload.trustedDomains": {
    "https://docs.renovatebot.com/": true
  },

  // ziglang.vscode-zig
  "zig.zls.enabled": "on",
  "zig.path": "zig",
  "zig.zls.path": "zls",
  "[zig]": {
    "editor.defaultFormatter": "ziglang.vscode-zig"
  },

  // jnoortheen.nix-ide
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide"
  },
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "nixpkgs": {
        "expr": "(builtins.getFlake (builtins.toString ./.)).outputs.nixpkgs.${builtins.currentSystem}"
      }
    }
  },

  // oxc.oxc-vscode
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true
}
