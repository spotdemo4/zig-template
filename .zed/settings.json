{
  "semantic_tokens": "combined",
  "prettier": {
    "allowed": false
  },
  "file_types": {
    "Shell Script": [".envrc*"]
  },
  "lsp": {
    "nixd": {
      "settings": {
        "nixpkgs": {
          "expr": "(builtins.getFlake (builtins.toString ./.)).outputs.nixpkgs.${builtins.currentSystem}"
        },
        "formatting": {
          "command": ["nixfmt"]
        }
      }
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "fmt.configPath": null,
          "run": "onSave"
        }
      }
    }
  },
  "languages": {
    "Zig": {
      "format_on_save": "on",
      "language_servers": ["zls"],
      "formatter": [
        {
          "language_server": {
            "name": "zls"
          }
        }
      ]
    },
    "JSON": {
      "format_on_save": "on",
      "language_servers": ["json-language-server", "oxfmt"],
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSONC": {
      "format_on_save": "on",
      "language_servers": ["json-language-server", "oxfmt"],
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Markdown": {
      "format_on_save": "on",
      "language_servers": ["oxfmt"],
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "YAML": {
      "format_on_save": "on",
      "language_servers": ["yaml-language-server", "oxfmt"],
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "TOML": {
      "format_on_save": "on",
      "language_servers": ["tombi", "oxfmt"],
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Nix": {
      "format_on_save": "on",
      "language_servers": ["nixd"],
      "formatter": [
        {
          "language_server": {
            "name": "nixd"
          }
        }
      ]
    }
  }
}
